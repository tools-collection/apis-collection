{
  "name": "apis-collection",
  "version": "2.0.0",
  "engines": {
    "node": ">=20"
  },
  "description": "Community maintained, human, machine and AI readable list of Public APIs 📝",
  "type": "module",
  "bin": {
    "apis": "./dist/cli.js"
  },
  "scripts": {
    "compile": "tsc",
    "prebuild": "tsc",
    "build": "node dist/cli.js build",
    "prevalidate": "tsc",
    "validate": "node dist/cli.js validate",
    "preadd": "tsc",
    "add": "node dist/cli.js add",
    "precheck-links": "tsc",
    "check-links": "node dist/cli.js check-links",
    "preenrich": "tsc",
    "enrich": "node dist/cli.js enrich",
    "premove-to-graveyard": "tsc",
    "move-to-graveyard": "node dist/cli.js move-to-graveyard",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.0",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "handlebars": "4.7.6",
    "inquirer": "13.2.5",
    "octokit": "^5.0.5",
    "p-limit": "7.3.0",
    "slugify": "1.4.6",
    "yaml": "2.8.2",
    "zod": "4.3.6"
  }
}
